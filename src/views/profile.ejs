<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Profil</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">

    <h2>Lost & Found</h2>

    <div>
        <a href="/market">Ogłoszenia</a>
        <a href="/logout">Wyloguj</a>
    </div>

</nav>

<div class="container">

    <div class="card">

        <h1>Witaj <%= user.name %></h1>

    </div>

    <div class="card">

        <h2>Dodaj zgłoszenie</h2>

        <form
            method="POST"
            action="/user/profile/add-item">

            <input
                type="text"
                name="name"
                placeholder="Nazwa przedmiotu"
                required>

            <textarea
                name="description"
                placeholder="Opis przedmiotu"
                required></textarea>

            <input
                type="text"
                name="location"
                placeholder="Lokalizacja"
                required>

            <select name="status">

                <option value="lost">
                    Zagubiono
                </option>

                <option value="found">
                    Znaleziono
                </option>

            </select>

            <button>
                Dodaj ogłoszenie
            </button>

        </form>

    </div>

    <div class="card">

        <h2>Moje zgłoszenia</h2>

        <% if(items.length === 0){ %>

            <p>
                Nie masz jeszcze żadnych zgłoszeń
            </p>

        <% } %>

        <% items.forEach(item => { %>

            <div class="user-item">

                <h3><%= item.name %></h3>

                <p>
                    <%= item.location %>
                </p>

                <a
                    href="/item/<%= item.id %>">
                    Zobacz
                </a>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>